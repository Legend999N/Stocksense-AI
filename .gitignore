# ── Python ────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyc
*.pyo
*.pyd
.Python

# ── Virtual Environment ───────────────────────────
venv/
env/
.env/
.venv/
ENV/

# ── Environment Variables ─────────────────────────
.env
.env.local
*.env

# ── Data Files ────────────────────────────────────
# Raw downloaded stock data — too large, re-fetchable
data/raw/
data/features/

# Keep the data folder structure itself
!data/.gitkeep
!data/raw/.gitkeep
!data/features/.gitkeep

# ── Trained Models ────────────────────────────────
# Large binary files — regenerated by running train.py
models/*.pkl
models/*.joblib
models/*.json
models/*.bin

# Keep models folder
!models/.gitkeep

# ── Jupyter Notebooks (checkpoints) ──────────────
.ipynb_checkpoints/
*.ipynb

# ── OS Files ──────────────────────────────────────
.DS_Store
.DS_Store?
._*
Thumbs.db
desktop.ini

# ── IDEs ──────────────────────────────────────────
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# ── Logs & Temp ───────────────────────────────────
*.log
*.tmp
*.temp
logs/

# ── HuggingFace / Transformers Cache ─────────────
# FinBERT downloads here — 440MB, not for git
.cache/
~/.cache/huggingface/
transformers_cache/

# ── Streamlit ─────────────────────────────────────
.streamlit/secrets.toml

# ── Testing ───────────────────────────────────────
.pytest_cache/
htmlcov/
.coverage